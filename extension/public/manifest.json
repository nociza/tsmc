{
  "manifest_version": 3,
  "name": "TSMC",
  "version": "0.2.0",
  "description": "Capture AI chat deltas from supported providers and sync them to a local TSMC backend.",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/*"
      ],
      "js": ["assets/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "commands": {
    "open-quick-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open TSMC search and inject on the current page"
    }
  },
  "options_page": "options.html",
  "action": {
    "default_title": "TSMC",
    "default_popup": "popup.html"
  }
}
