{
  "manifest_version": 3,
  "name": "SaveMyContext",
  "version": "0.2.0",
  "description": "Capture AI chat deltas from supported providers and sync them to a local SaveMyContext backend.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": ["assets/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "commands": {
    "open-quick-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open SaveMyContext search and inject on the current page"
    }
  },
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "SaveMyContext",
    "default_popup": "popup.html"
  }
}
