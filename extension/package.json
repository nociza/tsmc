{
  "name": "tsmc-extension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "debug:browser": "node scripts/manual-debug-browser.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests",
    "test:e2e": "pnpm build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
